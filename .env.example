# Application mode
CHALLENGE_MODE=true
KILL_SWITCH_ENABLED=false
SINK_ROUTING_ENABLED=false

# Deployed webhook server
RENDER_WEBHOOK_BASE_URL=https://your-render-service.onrender.com
WEBHOOK_ROUTE_RESEND=/webhooks/resend
WEBHOOK_ROUTE_AFRICASTALKING=/webhooks/africastalking
WEBHOOK_ROUTE_CALCOM=/webhooks/calcom

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=outreach@yourdomain.com
RESEND_REPLY_DOMAIN=chuairkoon.resend.app
RESEND_API_URL=https://api.resend.com
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_SIGNATURE_HEADER=resend-signature

# Africa's Talking (SMS)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SHORTCODE=
AFRICASTALKING_WEBHOOK_SECRET=
AFRICASTALKING_API_URL=https://api.africastalking.com/version1/messaging

# HubSpot remote MCP
HUBSPOT_MCP_SERVER_URL=https://mcp.hubspot.com
HUBSPOT_MCP_ACCESS_TOKEN=
HUBSPOT_MCP_REFRESH_TOKEN=
HUBSPOT_MCP_CLIENT_ID=
HUBSPOT_MCP_CLIENT_SECRET=
HUBSPOT_MCP_OAUTH_TOKEN_URL=https://api.hubapi.com/oauth/v1/token
HUBSPOT_MCP_PROTOCOL_VERSION=2025-06-18
HUBSPOT_MCP_TOOL_UPSERT_LEAD=
HUBSPOT_MCP_TOOL_APPEND_EVENT=
# Common value for both mappings in HubSpot remote MCP:
# HUBSPOT_MCP_TOOL_UPSERT_LEAD=manage_crm_objects
# HUBSPOT_MCP_TOOL_APPEND_EVENT=manage_crm_objects
HUBSPOT_MCP_REQUIRED_TOOLS_CSV=
HUBSPOT_MCP_REQUIRED_TOOL_COUNT=9
HUBSPOT_PIPELINE_ID=
# Optional company property projection for booking events (create these in HubSpot first).
HUBSPOT_COMPANY_PROP_LAST_BOOKING_ID=
HUBSPOT_COMPANY_PROP_LAST_BOOKING_START_AT=
HUBSPOT_COMPANY_PROP_LAST_BOOKING_END_AT=
HUBSPOT_COMPANY_PROP_LAST_BOOKING_TIMEZONE=
HUBSPOT_COMPANY_PROP_LAST_BOOKING_URL=
HUBSPOT_COMPANY_PROP_LAST_BOOKING_STATUS=

# Cal.com
CALCOM_API_URL=https://api.cal.com/v2
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_EVENT_TYPE_SLUG=
CALCOM_USERNAME=
CALCOM_WEBHOOK_SECRET=

# Tenacious playbook on disk (ICP, style guide, email sequences). Empty = repo ./tenacious_sales_data
TENACIOUS_SALES_DATA_PATH=

# Enrichment sources
CRUNCHBASE_DATASET_PATH=tenacious_sales_data/crunchbase-companies-information.csv
CRUNCHBASE_DATASET_URL=
LAYOFFS_CSV_PATH=
LAYOFFS_CSV_URL=
LEADERSHIP_FEED_URL=
CFPB_API_URL=https://www.consumerfinance.gov/data-research/consumer-complaints/search/api/v1/
CFPB_RESULT_LIMIT=100
ACT2_EVIDENCE_DIR=outputs/evidence/act2_enrichment
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-oss-120b:free
LLM_CALL_LOG_DIR=outputs/llm_calls

# Optional SerpAPI key (otherwise DuckDuckGo lite + Wikipedia search are used)
SERPAPI_API_KEY=

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Runtime
STATE_DB_PATH=outputs/runtime_state.db
HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

# Orchestration REST (FastAPI) — browser / SPA
# When set, all routes except /health, /docs, /openapi.json, /redoc require this value as
# header X-API-Key or Authorization: Bearer <ORCHESTRATION_API_KEY>. Leave empty for local-only.
ORCHESTRATION_API_KEY=
# Comma-separated extra browser origins (e.g. https://app.example.com). Local Next.js dev URLs are added automatically when true.
ORCHESTRATION_CORS_ORIGINS=
# When true (default), FastAPI CORS always includes http://localhost:3000 and http://127.0.0.1:3000. Set false in locked-down production.
ORCHESTRATION_CORS_ALLOW_LOCALHOST_DEV=true
